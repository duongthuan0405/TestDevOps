pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                bat 'echo "1. Building the project..."'
                bat 'echo "1. Build completed."'
            }

            post {
                always {
                    echo 'This will always run after the Build stage.'
                }
            }
        }

        stage('Test') {
            post {
                always {
                    echo 'This will always run after the Test stage.'
                }
            }
            steps {
                bat 'echo "1. Testing the application..."'
                bat 'echo "1. Testing completed."'
            }
        }

        stage('Deploy') {
            steps {
                bat 'echo "1. Deploying the application..."'
                bat 'echo "1.Deployment completed."'
            }

            post {
                always {
                    echo 'This will always run after the Deploy stage.'
                }
            }
        }
    }

    post {
        always {
            echo 'This will always run after the stages.'
        }
    }
}